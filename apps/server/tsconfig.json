{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../../packages/**/*.ts", "../../src/**/*.ts", "../../src/**/*.tsx"],
  "exclude": ["../../src/**/*.test.ts", "../../src/**/*.test.tsx", "../../packages/**/*.test.ts"]
}
