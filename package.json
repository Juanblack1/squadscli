{
  "name": "@juanblack1/squadscli",
  "version": "0.9.1",
  "description": "Orquestrador CLI do SquadsCli com runtime de squads, server HTTP, MCP, cockpit desktop e workflow universal para software e video.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "squadscli": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist",
    "apps",
    "docs",
    "README.md",
    ".env.example",
    ".npmrc.example",
    "skills",
    "scripts"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "build:server": "node -e \"require('fs').rmSync('apps/server/dist',{recursive:true,force:true})\" && npx tsc -p apps/server/tsconfig.json",
    "build:mcp": "node -e \"require('fs').rmSync('apps/mcp/dist',{recursive:true,force:true})\" && npx tsc -p apps/mcp/tsconfig.json",
    "build:all": "npm run build && npm run build:server && npm run build:mcp",
    "desktop:start": "electron apps/desktop/main.mjs",
    "desktop:dist": "npm run build:all && electron-builder --config apps/desktop/electron-builder.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build:all",
    "test": "vitest run",
    "check": "npm run build:all && npm run test"
  },
  "overrides": {
    "vite": "8.0.5"
  },
  "keywords": [
    "cli",
    "squadscli",
    "opensquad",
    "opencode",
    "openai",
    "gemini",
    "workflow",
    "prd",
    "techspec",
    "review",
    "mcp",
    "server",
    "retrieval",
    "video-editing"
  ],
  "author": "Juanblack1",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Juanblack1/squadscli.git"
  },
  "homepage": "https://github.com/Juanblack1/squadscli#readme",
  "bugs": {
    "url": "https://github.com/Juanblack1/squadscli/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@google/genai": "^1.24.0",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.104.0",
    "react": "^19.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
